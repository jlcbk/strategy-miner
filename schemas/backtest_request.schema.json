{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://strategy-miner.local/schemas/backtest_request.schema.json",
  "title": "回测请求",
  "type": "object",
  "required": ["kind", "title", "created_by", "strategy_name", "strategy_version", "data_window"],
  "properties": {
    "kind": { "const": "backtest_request" },
    "title": { "type": "string", "minLength": 1 },
    "created_by": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string" },
    "strategy_name": { "type": "string", "minLength": 1 },
    "strategy_version": { "type": "string", "minLength": 1 },
    "data_window": {
      "type": "object",
      "required": ["start_ts", "end_ts"],
      "properties": {
        "start_ts": { "type": "string" },
        "end_ts": { "type": "string" }
      },
      "additionalProperties": false
    },
    "symbols": { "type": "array", "items": { "type": "string" } },
    "exchanges": { "type": "array", "items": { "type": "string" } },
    "parameters": { "type": "object" }
  },
  "additionalProperties": false
}
