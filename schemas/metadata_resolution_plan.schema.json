{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://strategy-miner.local/schemas/metadata_resolution_plan.schema.json",
  "title": "元数据阻塞解决计划",
  "type": "object",
  "required": [
    "kind",
    "title",
    "created_by",
    "strategy_name",
    "blocked_requirement",
    "blocked_partitions",
    "blocker_reason",
    "accepted_resolution_paths",
    "reject_if",
    "output_partition_contract",
    "next_actions",
    "safety_boundary"
  ],
  "properties": {
    "kind": { "const": "metadata_resolution_plan" },
    "title": { "type": "string", "minLength": 1 },
    "created_by": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string" },
    "strategy_name": { "type": "string", "minLength": 1 },
    "issue_number": { "type": "integer" },
    "blocked_requirement": { "type": "string", "minLength": 1 },
    "blocked_partitions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "blocker_reason": { "type": "string", "minLength": 1 },
    "accepted_resolution_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "status",
          "description",
          "required_evidence",
          "allowed_downstream_state"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "required_evidence": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "minItems": 1
          },
          "allowed_downstream_state": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "manual_assumption_limits": { "type": "object" },
    "reject_if": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "output_partition_contract": { "type": "object" },
    "next_actions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "safety_boundary": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
